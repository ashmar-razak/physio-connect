# Local dev default: SQLite, zero setup required.
# To use Postgres instead, install Postgres and set:
# DATABASE_URL="postgresql://user:password@localhost:5432/physio_connect"
DATABASE_URL="file:./dev.db"

JWT_SECRET="change-this-to-a-long-random-string"
PORT=4000

# Optional: used for geocoding location text (postcode/city) into lat/lng.
# Nominatim (OpenStreetMap) requires no API key but asks for a contact email in the User-Agent.
GEOCODE_CONTACT_EMAIL="you@example.com"
